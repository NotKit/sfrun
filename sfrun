#!/usr/bin/env python3
"""sfrun - run Harbour Sailfish apps on Ubuntu Touch in a bwrap sandbox.

A Sailfish SDK target rootfs is mounted as the guest userspace inside an
unprivileged bubblewrap mount namespace; the host libhybris GL stack + Android
HAL are bound in; and the guest talks *directly* to Lomiri's Wayland compositor
over wl_shell. No container daemon, no nested compositor, no protocol proxy.

The bind/env recipe here is the one validated by Spike 1 on a MediaTek/Mali
UT 24.04 device (see spike/SPIKE1-FINDINGS.md). The key libhybris-on-UT pieces:
  - explicit Wayland EGL platform (eglGetPlatformDisplayEXT), EGL_PLATFORM=wayland
  - HYBRIS_LD_LIBRARY_PATH  : Android linker search path (VNDK/HAL libs)
  - HYBRIS_LINKER_DIR       : override hardcoded /usr/lib/.../libhybris/linker
  - HYBRIS_EGLPLATFORM_DIR  : where eglplatform_wayland.so lives
  - __EGL_VENDOR_LIBRARY_DIRS: host glvnd vendor JSON (guest /usr has none)
  - bind /dev/__properties__ + /android (with /apex,/linkerconfig symlinks)
  - DESKTOP_FILE_HINT=lomiri : satisfy Lomiri's Wayland confinement

Subcommands:
  doctor              Preflight checks.
  bootstrap [src]     Populate the guest rootfs from an SDK target tarball/dir
                      (no arg: download the latest target from Jolla).
  prepare-gl          Build the curated host-GL stack (run once, on-device).
  run <app> [args]    Launch an installed app id (or absolute binary path).
  spike               Run the bundled wl_shell+EGL test client (Spike 1).
"""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import getpass
import tarfile
from pathlib import Path

# --------------------------------------------------------------------------
# Layout. Everything lives under BASE (the project dir) because the UT rootfs
# is read-only; BASE must be on a writable fs (e.g. /home/phablet/sfrun).
# --------------------------------------------------------------------------

# CODE lives with the script (HERE: sfrun + shim/ + spike/), DATA lives under BASE
# (rootfs/, home/, hostgl/, glvnd/). They are decoupled so the script can be
# installed somewhere fixed and read-only (a click package under
# /opt/click.ubuntu.com/<pkg>/<version>/) while data sits in the user's XDG dir.
# Resolution order for BASE: $SFRUN_BASE, else the script dir if it already
# holds a rootfs (in-place/dev layout), else $XDG_DATA_HOME/<click pkg name>
# (the UT per-app data convention), else $XDG_DATA_HOME/sfrun.
HERE = Path(__file__).resolve().parent
SELF = Path(__file__).resolve()

# Click package roots on Ubuntu Touch (user-installed, preinstalled).
CLICK_ROOTS = ("/opt/click.ubuntu.com", "/usr/share/click/preinstalled")


def _click_pkg() -> str | None:
    """Click package name when running from an installed click
    (<root>/<pkg>/<version>/sfrun), else None."""
    for root in CLICK_ROOTS:
        try:
            return SELF.relative_to(root).parts[0]
        except ValueError:
            continue
    aid = os.environ.get("APP_ID", "")  # click launch: <pkg>_<app>_<version>
    if aid.count("_") >= 2:
        return aid.split("_")[0]
    return None


def stable_self() -> Path:
    """Path to this script that survives click upgrades: inside a click install
    prefer the package's `current` symlink over the versioned directory."""
    for root in CLICK_ROOTS:
        try:
            rel = SELF.relative_to(root)
        except ValueError:
            continue
        cur = Path(root, rel.parts[0], "current", *rel.parts[2:])
        if cur.exists():
            return cur
    return SELF


def _default_base() -> Path:
    if (HERE / "rootfs").is_dir() or (HERE / "home").is_dir():
        return HERE
    xdg = os.environ.get("XDG_DATA_HOME") or str(Path.home() / ".local/share")
    return Path(xdg) / (_click_pkg() or "sfrun")


BASE = Path(os.environ["SFRUN_BASE"]) if os.environ.get("SFRUN_BASE") else _default_base()
ROOTFS = Path(os.environ.get("SFRUN_ROOTFS", str(BASE / "rootfs")))
HOSTGL = Path(os.environ.get("SFRUN_HOSTGL", str(BASE / "hostgl")))
GLVND = Path(os.environ.get("SFRUN_GLVND", str(BASE / "glvnd")))
# Single shared guest home, like a real Sailfish device (apps separate their data
# by ~/.local/share/<App>). Runs as the device user (Sailfish allows any login
# name), so the uid resolves in passwd (needed by dbus/dconf).
DEV_USER = os.environ.get("SFRUN_USER", getpass.getuser())
DEV_UID = os.getuid()
DEV_GID = os.getgid()
GUEST_HOME = f"/home/{DEV_USER}"
HOME_DIR = Path(os.environ.get("SFRUN_HOME", str(BASE / "home")))
# CODE dir is exposed at /sfcode inside the sandbox; DATA dir (BASE) at /sfhome.
SHIM = Path(os.environ.get("SFRUN_SHIM", str(HERE / "shim" / "libsailfish-shim.so")))
SHIM_GUEST = "/sfcode/shim/libsailfish-shim.so"

# Host libhybris install dir (multiarch triplet on UT).
HOST_TRIPLET = Path(os.environ.get("SFRUN_HOST_TRIPLET", "/usr/lib/aarch64-linux-gnu"))
HOST_GLVND_VENDOR = Path("/usr/share/glvnd/egl_vendor.d")

# Android runtime knobs. SDK version drives the VNDK apex path.
ANDROID_SDK = os.environ.get("SFRUN_ANDROID_SDK", "")  # autodetected if empty

# Where SDK target tarballs are fetched from (bootstrap downloads straight from
# Jolla to the user's device — we never redistribute the rootfs ourselves).
SDK_TARGETS_URL = os.environ.get(
    "SFRUN_TARGETS_URL", "https://releases.sailfishos.org/sdk/targets/")
TARGET_ARCH = os.environ.get("SFRUN_TARGET_ARCH", "aarch64")


# --------------------------------------------------------------------------
# Host -> guest binds.
#   HAL_BINDS : libhybris Android roots + the /android tree (apex/linkerconfig).
#   DEV_NODES : GPU + IPC + Android property store. Bound if present on host.
# --------------------------------------------------------------------------

HAL_BINDS = ["/system", "/vendor", "/odm", "/android"]

DEV_NODES = [
    "/dev/dri", "/dev/mali0", "/dev/kgsl-3d0",        # GPU (Mali or Adreno)
    "/dev/ion", "/dev/dma_heap",                       # buffer allocators
    "/dev/binder", "/dev/hwbinder", "/dev/vndbinder",  # binder IPC
    "/dev/__properties__", "/dev/socket",              # Android property store
]

# Guest rootfs top-level dirs we provide ourselves (don't ro-bind from rootfs).
PROVIDED = {"dev", "proc", "tmp", "run", "sys",
            "system", "vendor", "odm", "android", "apex", "linkerconfig", "home"}

# Host GL/hybris libs to copy into the curated HOSTGL dir (prepare-gl). Real
# copies, not symlinks (symlinks would dangle inside the namespace). Core glibc
# libs are deliberately excluded so the guest's newer glibc stays in use.
GL_LIB_PATTERNS = [
    "libEGL*", "libGLES*", "libGL.so*", "libGLdispatch*", "libOpenGL*",
    "libGLX*", "libglvnd*", "libgbm*", "libdrm*", "libwayland-egl*",
    "libhybris*", "libhardware*", "libsync*", "libglapi*", "libexpat*",
    "libgralloc*", "libui*", "libcutils*", "libutils*",
    # bionic-TLS reservation shim: libhybris GL stores the EGL context in a
    # bionic TLS slot that clobbers glibc TLS across threads without this.
    # UT preloads it into every hybris Qt app.
    "libtls-padding*",
]


def android_sdk() -> str:
    if ANDROID_SDK:
        return ANDROID_SDK
    try:
        out = subprocess.run(["getprop", "ro.build.version.sdk"],
                             capture_output=True, text=True, timeout=5)
        v = out.stdout.strip()
        if v:
            return v
    except Exception:
        pass
    return "34"


def hybris_ld_library_path() -> str:
    sdk = android_sdk()
    return ":".join([
        "/system/lib64",
        f"/apex/com.android.vndk.v{sdk}/lib64",
        "/vendor/lib64/hw", "/vendor/lib64/egl", "/vendor/lib64",
    ])


# --------------------------------------------------------------------------
# Environment handed to the guest process.
# --------------------------------------------------------------------------

def guest_env(app_data: Path) -> dict[str, str]:
    xdg = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    wl = os.environ.get("WAYLAND_DISPLAY", "wayland-0")
    env = {
        "HOME": GUEST_HOME,
        "USER": DEV_USER,
        "XDG_RUNTIME_DIR": xdg,
        "WAYLAND_DISPLAY": wl,
        # talk straight to Lomiri over wl_shell. Do NOT set
        # QT_WAYLAND_SHELL_INTEGRATION: when set, Sailfish's QtWayland 5.6 uses
        # the plugin factory (its wayland-shell-integration dir is empty -> null
        # -> crash). When unset, it falls to a *built-in* path that does
        # `new QWaylandWlShellIntegration` directly once it sees the wl_shell
        # registry global (which Lomiri advertises). See spike/SPIKE2-FINDINGS.
        "QT_QPA_PLATFORM": "wayland",
        # Maliit keyboard: both SFOS and UT use Maliit 2.3.x over D-Bus.
        # The session bus (bound from host) carries org.maliit.Server.Address
        # which points the input context plugin to the maliit-server socket.
        "QT_IM_MODULE": "maliit",
        "QT_WAYLAND_DISABLE_WINDOWDECORATION": "1",
        # libhybris EGL can't share a GL context across threads, so the
        # threaded scene-graph render loop aborts ("makeCurrent in a different
        # thread"). Force the single-threaded render loop.
        "QSG_RENDER_LOOP": "basic",
        # --- the validated libhybris-on-UT EGL recipe ---
        "EGL_PLATFORM": "wayland",
        "HYBRIS_EGLPLATFORM": "wayland",
        "HYBRIS_EGLPLATFORM_DIR": "/hostgl",
        "HYBRIS_LINKER_DIR": "/hostgl/linker",
        "HYBRIS_ANDROID_SDK_VERSION": android_sdk(),
        "HYBRIS_LD_LIBRARY_PATH": hybris_ld_library_path(),
        "__EGL_VENDOR_LIBRARY_DIRS": "/hostglvnd",
        "LD_LIBRARY_PATH": "/hostgl:/usr/lib64:/lib64",
        # Lomiri Wayland confinement needs a desktop hint to allow the connection.
        # When launched from a .desktop, Lomiri sets DESKTOP_FILE_HINT itself —
        # inherit that; only default to "lomiri" for a manual CLI launch.
        "DESKTOP_FILE_HINT": os.environ.get("DESKTOP_FILE_HINT", "lomiri"),
        # Silica theme / QML lookup (guest libdir is /usr/lib64).
        "XDG_DATA_DIRS": "/usr/share",
        "QML2_IMPORT_PATH": "/usr/lib64/qt5/qml",
        "QT_PLUGIN_PATH": "/usr/lib64/qt5/plugins",
        # tls-padding is mandatory for hybris GL; the compat shim is optional
        # (referenced at its in-sandbox /sfcode path).
        "LD_PRELOAD": ":".join(p for p in ("/hostgl/libtls-padding.so",
                                           SHIM_GUEST if SHIM.exists() else "") if p),
    }
    for k in ("LANG", "LC_ALL", "DBUS_SESSION_BUS_ADDRESS",
              "DBUS_SYSTEM_BUS_ADDRESS", "SFRUN_DEBUG"):
        if k in os.environ:
            env[k] = os.environ[k]
    # Allow overriding selected keys from the caller's env (debugging: shell
    # integration, Qt/scene-graph logging) without editing this file.
    # NOTE: QT_QPA_PLATFORM is deliberately NOT inherited. Lomiri injects a
    # multi-value list (e.g. "ubuntumirclient;wayland-egl;xcb") which Sailfish's
    # Qt 5.6 rejects; we always force the single value "wayland" set above.
    for k in ("QT_WAYLAND_SHELL_INTEGRATION", "QT_WAYLAND_USE_XDG_SHELL",
              "QT_LOGGING_RULES", "QSG_INFO", "QT_QPA_EGLFS_DEBUG",
              "QT_DEBUG_PLUGINS", "QT_WAYLAND_DISABLE_WINDOWDECORATION",
              # Sailfish routes Qt logging to journald by default; force stderr.
              "QT_LOGGING_TO_CONSOLE", "QT_MESSAGE_PATTERN"):
        if k in os.environ:
            env[k] = os.environ[k]
    return env


# --------------------------------------------------------------------------
# bwrap argv assembly
# --------------------------------------------------------------------------

def ensure_user() -> None:
    """Make the device user resolvable inside the guest (dbus/dconf/getpwuid need
    it). Sailfish allows any login name, so we reuse the host user + uid; written
    host-side into the rootfs passwd/group (idempotent)."""
    pw, gr = ROOTFS / "etc/passwd", ROOTFS / "etc/group"
    if pw.is_file() and not any(l.startswith(DEV_USER + ":")
                                for l in pw.read_text().splitlines()):
        pw.write_text(pw.read_text().rstrip("\n") +
                      f"\n{DEV_USER}:x:{DEV_UID}:{DEV_GID}:{DEV_USER}:{GUEST_HOME}:/bin/bash\n")
    if gr.is_file() and not any(l.startswith(DEV_USER + ":")
                                for l in gr.read_text().splitlines()):
        gr.write_text(gr.read_text().rstrip("\n") + f"\n{DEV_USER}:x:{DEV_GID}:\n")


def build_bwrap_argv(inner_argv: list[str]) -> list[str]:
    if not ROOTFS.is_dir():
        die(f"guest rootfs not found at {ROOTFS}; run `sfrun bootstrap <src>` first")
    if not HOSTGL.is_dir() or not (HOSTGL / "linker").is_dir():
        die(f"host-GL stack not built at {HOSTGL}; run `sfrun prepare-gl` first")
    ensure_user()

    argv: list[str] = [
        "bwrap",
        "--unshare-user", "--unshare-ipc", "--die-with-parent",
        "--proc", "/proc",
        "--dev", "/dev",
        "--tmpfs", "/tmp",
        "--tmpfs", "/run",
    ]

    # guest rootfs as / (top dirs individually; skip what we provide ourselves).
    for entry in sorted(ROOTFS.iterdir(), key=lambda p: p.name):
        if entry.name in PROVIDED:
            continue
        argv += ["--ro-bind", str(entry), f"/{entry.name}"]

    # libhybris HAL roots + android tree.
    for p in HAL_BINDS:
        if Path(p).exists():
            argv += ["--ro-bind", p, p]
        else:
            warn(f"skip HAL bind (missing): {p}")
    # apex / linkerconfig are symlinks into /android on UT; recreate them.
    if Path("/android").exists():
        argv += ["--symlink", "/android/apex", "/apex",
                 "--symlink", "/android/linkerconfig", "/linkerconfig"]

    # curated host GL stack + host glvnd vendor JSON.
    argv += ["--ro-bind", str(HOSTGL), "/hostgl"]
    argv += ["--ro-bind", str(GLVND), "/hostglvnd"]

    # GPU / IPC / property-store device nodes (only those present).
    for node in DEV_NODES:
        if Path(node).exists():
            argv += ["--dev-bind", node, node]

    # host runtime dir (Wayland + pulse + dbus session sockets).
    xdg = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    if Path(xdg).exists():
        argv += ["--bind", xdg, xdg]

    # host system D-Bus socket (connman, ofono live here).
    for sysbus in ("/run/dbus/system_bus_socket", "/var/run/dbus/system_bus_socket"):
        if Path(sysbus).exists():
            # rw-bind the socket + its parent dir so the guest can find it.
            argv += ["--bind", str(Path(sysbus).parent), str(Path(sysbus).parent)]
            break

    # host DNS resolution (resolv.conf + hosts).
    for dns in ("/etc/resolv.conf", "/etc/hosts"):
        if Path(dns).exists():
            argv += ["--ro-bind", dns, dns]

    # single shared writable HOME (like a real device; apps split data by subdir).
    HOME_DIR.mkdir(parents=True, exist_ok=True)
    argv += ["--bind", str(HOME_DIR), GUEST_HOME]
    # data dir at /sfhome, code dir (shim, spike) at /sfcode.
    argv += ["--ro-bind", str(BASE), "/sfhome"]
    argv += ["--ro-bind", str(HERE), "/sfcode"]

    argv += ["--clearenv"]
    for k, v in guest_env(HOME_DIR).items():
        if v:
            argv += ["--setenv", k, v]

    argv += ["--"]
    argv += inner_argv
    return argv


